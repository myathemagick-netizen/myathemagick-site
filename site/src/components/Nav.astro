---
const links = [
  { href: "/system", label: "The System" },
  { href: "/tools", label: "Tools" },
  { href: "/writing", label: "Writing" },
  { href: "/watch", label: "Watch" },
  { href: "/music", label: "Music" },
  { href: "/about", label: "About" },
];

const currentPath = Astro.url.pathname;
---

<nav>
  <a href="/" class="nav-logo">
    <svg viewBox="0 0 100 100" width="24" height="24">
      <defs>
        <linearGradient id="nhg" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#c084fc"/>
          <stop offset="100%" stop-color="#6d28d9"/>
        </linearGradient>
      </defs>
      <rect width="100" height="100" rx="18" fill="#09090f"/>
      <polygon points="50,8 85,29 85,71 50,92 15,71 15,29" fill="url(#nhg)"/>
    </svg>
    <span>Myathe Magick</span>
  </a>
  <div class="nav-links">
    {links.map(link => (
      <a href={link.href} class={currentPath === link.href || currentPath.startsWith(link.href + '/') ? "active" : ""}>
        {link.label}
      </a>
    ))}
  </div>
</nav>

<style>
  
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 40px;
    border-bottom: 1px solid rgba(139,92,246,0.1);
    position: sticky;
    top: 0;
    background: rgba(9,9,15,0.95);
    backdrop-filter: blur(8px);
    z-index: 100;
  }
  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'Cinzel', serif;
    font-size: 13px;
    letter-spacing: 0.3em;
    color: #9d8cd4;
    text-decoration: none;
  }
  .nav-logo:hover { color: #c4b5fd; }
  .nav-links {
    display: flex;
    gap: 28px;
  }
  .nav-links a {
    font-family: 'Cinzel', serif;
    font-size: 11px;
    letter-spacing: 0.22em;
    color: #3d2f5c;
    text-decoration: none;
    transition: color 0.15s;
  }
  .nav-links a:hover, .nav-links a.active { color: #9d8cd4; }

  @media (max-width: 800px) {
    nav {
      padding: 12px 16px;
    }
    .nav-links {
      display: none;
    }
    .nav-logo span {
      font-size: 11px;
      letter-spacing: 0.2em;
    }
  }


</style>