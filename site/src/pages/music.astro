---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allTracks = await getCollection('music');
const sorted = allTracks.sort((a, b) => {
  if (a.data.volume !== b.data.volume) return a.data.volume - b.data.volume;
  return a.data.track - b.data.track;
});
---

<Layout title="Music">

  <div class="page-header">
    <div class="eyebrow">Music · MTA Catalog</div>
    <h1>Metis Temp Agency<br><em>audio transmissions</em></h1>
    <div class="mta-badge">
      <div class="mta-line">METIS TEMP AGENCY // AUDIO DIV.</div>
      <div class="mta-line">STATUS: <span>ACTIVE TRANSMISSION</span></div>
      <div class="mta-line">CATALOG REF: <span>MTA-AUDIO-2025</span></div>
      <div class="mta-line">CLEARANCE: <span>OPEN</span></div>
      <div class="mta-line">DIRECTIVE: <span>SHIFT YOUR FREQUENCY</span><span class="blink"></span></div>
    </div>
  </div>

  <div class="tracklist" id="tracklist">
    <div class="vol-header">
      <span class="vol-title">Volume I</span>
      <span class="vol-meta">{sorted.length} TRACKS · MTA-001</span>
    </div>

    {sorted.map((track, i) => (
      <div class="track" id={`track-${i}`} data-url={track.data.audioUrl} data-index={i} onclick={`playTrack(${i}, '${track.data.audioUrl}', '${track.data.title}')`}>
        <div class="track-num">
          <span class="num">{String(track.data.track).padStart(2,'0')}</span>
          <div class="bars" id={`bars-${i}`} style="display:none">
            <div class="bar"></div>
            <div class="bar"></div>
            <div class="bar"></div>
          </div>
        </div>
        <div class="track-info">
          <div class="track-title">{track.data.title}</div>
          <div class="track-flavor">{track.data.flavor}</div>
        </div>
        <div class="track-right">
          <span class="track-tag">{track.data.tag}</span>
          {track.data.duration && <span class="track-dur">{track.data.duration}</span>}
        </div>
      </div>
    ))}
  </div>

  <div class="mta-footer-note">
    <div class="mta-classified">
      METIS TEMP AGENCY — full site coming.<br/>
      <a href="/system">CLASSIFIED: learn more about MTA ↗</a>
    </div>
    <div class="mta-credits">
      AUDIO: SUNO AI GENERATION<br/>
      SIGIL INTENT: MYATHE MAGICK SYSTEM<br/>
      ALL TRANSMISSIONS: CC BY-NC
    </div>
  </div>

  <!-- STICKY PLAYER -->
  <div class="player" id="player">
    <div class="player-track">
    <img id="cover-art" style="display:none; width:48px; height:48px; object-fit:cover; border-radius:2px; flex-shrink:0;" />
    <div>
        <div class="player-title" id="player-title">Select a track</div>
        <div class="player-sub" id="player-sub">MTA AUDIO DIVISION</div>
   </div>
   </div>
    <div class="player-controls">
      <div class="ctrl-btns">
        <button class="ctrl-btn" onclick="prevTrack()" aria-label="Previous">⏮</button>
        <button class="ctrl-play" onclick="togglePlay()" id="play-btn" aria-label="Play">▶</button>
        <button class="ctrl-btn" onclick="nextTrack()" aria-label="Next">⏭</button>
      </div>
      <div class="progress-row">
        <span class="prog-time" id="current-time">0:00</span>
        <div class="prog-bar" onclick="seek(event)" id="prog-bar">
          <div class="prog-fill" id="prog-fill"></div>
        </div>
        <span class="prog-time" id="total-time">0:00</span>
      </div>
    </div>
    <div class="player-right">
      <span class="vol-icon">🔊</span>
      <input type="range" class="vol-slider" id="vol-slider" min="0" max="1" step="0.05" value="0.8" oninput="setVolume(this.value)"/>
      <a href="/system" class="mta-link">MTA ↗</a>
    </div>
  </div>

  <footer>
    <div class="footer-logo">Myathe Magick System</div>
    <div class="footer-links">
      <a href="https://youtube.com/channel/UClWbNxQMrx-XB3h8xXh_oxQ/" target="_blank">YouTube</a>
      <a href="https://myathemagick.substack.com/" target="_blank">Substack</a>
      <a href="https://ko-fi.com/myathemagick" target="_blank">Ko-fi</a>
      <a href="https://www.facebook.com/profile.php?id=61563102456940" target="_blank">Facebook</a>
      <a href="https://x.com/MyatheMagick" target="_blank">X</a>
    </div>
  </footer>

</Layout>

<audio id="audio-player" preload="none"></audio>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jsmediatags/3.9.5/jsmediatags.min.js" defer></script>
<script is:inline>
  let audio = document.getElementById('audio-player');
  let currentIndex = -1;
  let isPlaying = false;
  const tracks = [...document.querySelectorAll('.track')];

  function formatTime(s) {
    if (isNaN(s)) return '0:00';
    const m = Math.floor(s / 60);
    const sec = Math.floor(s % 60);
    return `${m}:${sec.toString().padStart(2,'0')}`;
  }

function loadCoverArt(url) {
  window.jsmediatags.read(url, {
    onSuccess: function(tag) {
      const image = tag.tags.picture;
      if (image) {
        const blob = new Blob([new Uint8Array(image.data)], { type: image.format });
        const imgUrl = URL.createObjectURL(blob);
        document.getElementById('cover-art').src = imgUrl;
        document.getElementById('cover-art').style.display = 'block';
      }
    },
    onError: function(error) {
      console.log('No cover art:', error);
    }
  });
}

  function playTrack(index, url, title) {
    // Remove playing state from all tracks
    tracks.forEach((t, i) => {
      t.classList.remove('playing');
      document.querySelector(`#bars-${i}`).style.display = 'none';
      document.querySelector(`#track-${i} .num`).style.display = 'inline';
    });

    currentIndex = index;
    audio.src = url;
    audio.volume = parseFloat(document.getElementById('vol-slider').value);
    audio.play();
    isPlaying = true;

    // Set playing state
    tracks[index].classList.add('playing');
    document.querySelector(`#bars-${index}`).style.display = 'flex';
    document.querySelector(`#track-${index} .num`).style.display = 'none';
    document.getElementById('play-btn').textContent = '⏸';
    document.getElementById('player-title').textContent = title;
    document.getElementById('player-sub').textContent = `MTA VOL. I · TRACK ${String(index + 1).padStart(2,'0')}`;
    if (window.jsmediatags) {
    loadCoverArt(url);
    } else {
    console.log('jsmediatags not loaded yet');
    }
  }

  function togglePlay() {
    if (currentIndex === -1) return;
    if (isPlaying) {
      audio.pause();
      isPlaying = false;
      document.getElementById('play-btn').textContent = '▶';
      document.querySelector(`#bars-${currentIndex}`).style.display = 'none';
      document.querySelector(`#track-${currentIndex} .num`).style.display = 'inline';
    } else {
      audio.play();
      isPlaying = true;
      document.getElementById('play-btn').textContent = '⏸';
      document.querySelector(`#bars-${currentIndex}`).style.display = 'flex';
      document.querySelector(`#track-${currentIndex} .num`).style.display = 'none';
    }
  }

  function prevTrack() {
    if (currentIndex <= 0) return;
    const prev = tracks[currentIndex - 1];
    playTrack(currentIndex - 1, prev.dataset.url, prev.querySelector('.track-title').textContent);
  }

  function nextTrack() {
    if (currentIndex >= tracks.length - 1) return;
    const next = tracks[currentIndex + 1];
    playTrack(currentIndex + 1, next.dataset.url, next.querySelector('.track-title').textContent);
  }

  function setVolume(val) {
    audio.volume = parseFloat(val);
  }

  function seek(e) {
    const bar = document.getElementById('prog-bar');
    const rect = bar.getBoundingClientRect();
    const pct = (e.clientX - rect.left) / rect.width;
    audio.currentTime = pct * audio.duration;
  }

  audio.addEventListener('timeupdate', () => {
    const pct = (audio.currentTime / audio.duration) * 100;
    document.getElementById('prog-fill').style.width = `${pct}%`;
    document.getElementById('current-time').textContent = formatTime(audio.currentTime);
    document.getElementById('total-time').textContent = formatTime(audio.duration);
  });

  audio.addEventListener('ended', () => {
    nextTrack();
  });
</script>

<style>
  :global(body) { overflow-x: hidden; }

  .page-header {
    padding: 56px 40px 48px;
    border-bottom: 1px solid rgba(139,92,246,0.08);
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 48px;
    align-items: end;
  }
  .eyebrow {
    font-size: 10px;
    letter-spacing: 0.5em;
    color: #6d5a8a;
    margin-bottom: 16px;
    font-family: 'Cinzel', serif;
    text-transform: uppercase;
  }
  h1 {
    font-family: 'Cinzel', serif;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 400;
    color: #f0ecff;
    margin: 0;
    letter-spacing: 0.04em;
    line-height: 1.3;
  }
  h1 em {
    font-style: italic;
    font-family: 'Crimson Pro', serif;
    color: #a78bfa;
  }

  .mta-badge {
    background: #0d0d1a;
    border: 1px solid rgba(139,92,246,0.15);
    padding: 20px 24px;
    font-family: 'Share Tech Mono', 'Courier New', monospace;
    white-space: nowrap;
  }
  .mta-line {
    font-size: 11px;
    color: #4c3d6e;
    line-height: 2;
  }
  .mta-line span { color: #7c6a99; }
  .blink {
    display: inline-block;
    width: 8px; height: 12px;
    background: #4c3d6e;
    margin-left: 4px;
    vertical-align: middle;
    animation: blink 1.2s step-end infinite;
  }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

  /* TRACKLIST */
  .tracklist {
    border-bottom: 1px solid rgba(139,92,246,0.06);
  }
  .vol-header {
    padding: 28px 40px 16px;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
  }
  .vol-title {
    font-family: 'Cinzel', serif;
    font-size: 15px;
    color: #9d8cd4;
    font-weight: 400;
    letter-spacing: 0.06em;
  }
  .vol-meta {
    font-family: 'Courier New', monospace;
    font-size: 11px;
    color: #4c3d6e;
  }

  .track {
    display: grid;
    grid-template-columns: 56px 1fr auto;
    align-items: center;
    border-top: 1px solid rgba(139,92,246,0.05);
    cursor: pointer;
    transition: background 0.12s;
  }
  .track:hover { background: rgba(109,40,217,0.05); }
  .track.playing { background: rgba(109,40,217,0.08); }

  .track-num {
    padding: 20px 0 20px 40px;
    font-family: 'Courier New', monospace;
    font-size: 11px;
    color: #4c3d6e;
    display: flex;
    align-items: center;
  }
  .track.playing .track-num { color: #a78bfa; }

  .bars {
    display: flex;
    align-items: flex-end;
    gap: 2px;
    height: 14px;
  }
  .bar {
    width: 3px;
    background: #a78bfa;
    border-radius: 1px;
    animation: barwave 0.8s ease-in-out infinite;
  }
  .bar:nth-child(2) { animation-delay: 0.15s; }
  .bar:nth-child(3) { animation-delay: 0.3s; }
  @keyframes barwave { 0%,100%{height:4px} 50%{height:14px} }

  .track-info { padding: 20px 16px; }
  .track-title {
    font-size: 15px;
    color: #9d8ab5;
    font-weight: 300;
    margin-bottom: 4px;
    transition: color 0.12s;
  }
  .track:hover .track-title,
  .track.playing .track-title { color: #c4b5fd; }
  .track-flavor {
    font-family: 'Courier New', monospace;
    font-size: 10px;
    color: #4c3d6e;
    line-height: 1.5;
  }
  .track.playing .track-flavor { color: #6d5a8a; }

  .track-right {
    padding: 20px 40px 20px 0;
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .track-tag {
    font-size: 9px;
    letter-spacing: 0.2em;
    color: #4c3d6e;
    font-family: 'Cinzel', serif;
    border: 1px solid rgba(139,92,246,0.12);
    padding: 3px 8px;
  }
  .track.playing .track-tag {
    border-color: rgba(167,139,250,0.25);
    color: #7c6a99;
  }
  .track-dur {
    font-family: 'Courier New', monospace;
    font-size: 11px;
    color: #4c3d6e;
  }

  /* MTA FOOTER NOTE */
  .mta-footer-note {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24px 40px;
    border-bottom: 1px solid rgba(139,92,246,0.06);
    flex-wrap: wrap;
    gap: 16px;
  }
  .mta-classified {
    font-family: 'Courier New', monospace;
    font-size: 11px;
    color: #4c3d6e;
    line-height: 2;
  }
  .mta-classified a {
    color: #6d5a8a;
    text-decoration: none;
    transition: color 0.15s;
  }
  .mta-classified a:hover { color: #9d8cd4; }
  .mta-credits {
    font-family: 'Courier New', monospace;
    font-size: 10px;
    color: #3d2f5c;
    text-align: right;
    line-height: 2;
  }

  /* STICKY PLAYER */
  .player {
    position: sticky;
    bottom: 0;
    background: #0a0a12;
    border-top: 1px solid rgba(139,92,246,0.15);
    padding: 0 40px;
    display: grid;
    grid-template-columns: 1fr 2fr 1fr;
    align-items: center;
    gap: 24px;
    height: 72px;
    z-index: 100;
  }
    .player-track {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 12px;
    overflow: hidden;
  }
  .player-title {
    font-size: 13px;
    color: #c4b5fd;
    font-weight: 300;
    margin-bottom: 3px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .player-sub {
    font-family: 'Courier New', monospace;
    font-size: 10px;
    color: #4c3d6e;
  }

  .player-controls {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }
  .ctrl-btns {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .ctrl-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: #6d5a8a;
    font-size: 14px;
    padding: 0;
    transition: color 0.15s;
  }
  .ctrl-btn:hover { color: #9d8cd4; }
  .ctrl-play {
    width: 36px; height: 36px;
    border-radius: 50%;
    border: 1px solid rgba(167,139,250,0.3);
    background: rgba(109,40,217,0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    font-size: 14px;
    color: #c4b5fd;
    transition: background 0.2s;
  }
  .ctrl-play:hover { background: rgba(109,40,217,0.28); }

  .progress-row {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .prog-time {
    font-family: 'Courier New', monospace;
    font-size: 10px;
    color: #4c3d6e;
    min-width: 32px;
  }
  .prog-bar {
    flex: 1;
    height: 3px;
    background: rgba(139,92,246,0.12);
    border-radius: 2px;
    cursor: pointer;
    position: relative;
  }
  .prog-fill {
    height: 100%;
    background: rgba(167,139,250,0.5);
    border-radius: 2px;
    width: 0%;
    transition: width 0.1s linear;
  }

  .player-right {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 12px;
  }
  .vol-icon { font-size: 14px; }
  .vol-slider {
    width: 80px;
    accent-color: #7c3aed;
    cursor: pointer;
  }
  .mta-link {
    font-family: 'Courier New', monospace;
    font-size: 10px;
    color: #4c3d6e;
    letter-spacing: 0.1em;
    text-decoration: none;
    transition: color 0.15s;
  }
  .mta-link:hover { color: #7c6a99; }

  /* FOOTER */
  footer {
    padding: 32px 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid rgba(139,92,246,0.08);
    margin-bottom: 72px;
  }
  .footer-logo {
    font-family: 'Cinzel', serif;
    font-size: 11px;
    letter-spacing: 0.3em;
    color: #6d5a8a;
  }
  .footer-links { display: flex; gap: 24px; }
  .footer-links a {
    font-size: 11px;
    letter-spacing: 0.15em;
    color: #6d5a8a;
    font-family: 'Cinzel', serif;
    transition: color 0.15s;
    text-decoration: none;
  }
  .footer-links a:hover { color: #c4b5fd; }

  @media (max-width: 800px) {
    .page-header {
      grid-template-columns: 1fr;
      padding: 40px 24px 32px;
      gap: 24px;
    }
    .mta-badge { white-space: normal; }
    .vol-header { padding: 20px 24px 12px; }
    .track { grid-template-columns: 44px 1fr auto; }
    .track-num { padding-left: 24px; }
    .track-right { padding-right: 24px; gap: 10px; }
    .mta-footer-note { padding: 20px 24px; }
    .mta-credits { text-align: left; }
    .player {
      grid-template-columns: 1fr 1fr;
      height: auto;
      padding: 12px 20px;
      gap: 12px;
    }
    .player-right { display: none; }
    footer {
      flex-direction: column;
      gap: 20px;
      text-align: center;
      padding: 28px 24px;
      margin-bottom: 100px;
    }
    .footer-links { flex-wrap: wrap; justify-content: center; }
  }
</style>