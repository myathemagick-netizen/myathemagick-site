---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const allVideos = await getCollection('videos');

const featured = allVideos.find(v => v.data.featured === true);
const essays = allVideos.filter(v => v.data.category === 'essay');
const music = allVideos.filter(v => v.data.category === 'music');
const shorts = allVideos.filter(v => v.data.category === 'short');
---

<Layout title="Watch">

  <!-- HEADER -->
  <div class="page-header">
    <div class="eyebrow">Watch</div>
    <h1>The moving archive</h1>
    <p class="intro">Essay videos, music, and Nyx Nightshade transmissions — organized by type, tagged by theme.</p>
  </div>

  <!-- FEATURED -->
  {featured && (
    <div class="featured-wrap">
      <div class="section-label">Start here</div>
      <div class="featured">
        <a href={`https://youtube.com/watch?v=${featured.data.youtubeId}`} target="_blank" class="featured-thumb">
          <img src={`https://img.youtube.com/vi/${featured.data.youtubeId}/maxresdefault.jpg`} alt={featured.data.title} loading="lazy"/>
          <div class="play-overlay">
            <div class="play-btn">▶</div>
          </div>
        </a>
        <div class="featured-info">
          <div class="featured-badge">Featured</div>
          <h2>{featured.data.title}</h2>
          <p>{featured.data.description}</p>
          <a href={`https://youtube.com/watch?v=${featured.data.youtubeId}`} target="_blank" class="watch-btn">↗ Watch on YouTube</a>
        </div>
      </div>
    </div>
  )}

  <!-- ESSAYS -->
  <div class="section">
    <div class="section-head">
      <div class="section-label">Essay videos</div>
      <a href="https://youtube.com/channel/UClWbNxQMrx-XB3h8xXh_oxQ/" target="_blank" class="section-more">Full channel ↗</a>
    </div>
    <div class="section-desc">Long-form investigations. Each paired with an expanded essay on Substack.</div>
    <div class="video-grid">
      {essays.map(v => (
        <a href={`https://youtube.com/watch?v=${v.data.youtubeId}`} target="_blank" class="video-card">
          <div class="thumb">
            <img src={`https://img.youtube.com/vi/${v.data.youtubeId}/mqdefault.jpg`} alt={v.data.title} loading="lazy"/>
            <div class="play-overlay-sm">▶</div>
          </div>
          <div class="card-body">
            <div class="card-tag">{v.data.theme}</div>
            <div class="card-title">{v.data.title}</div>
            <div class="card-desc">{v.data.description}</div>
          </div>
        </a>
      ))}
    </div>
  </div>

  <!-- MUSIC -->
  <div class="section">
    <div class="section-head">
      <div class="section-label">Music videos</div>
    </div>
    <div class="section-desc">MTA catalog — Suno-generated transmissions with visuals.</div>
    <div class="video-grid">
      {music.map(v => (
        <a href={`https://youtube.com/watch?v=${v.data.youtubeId}`} target="_blank" class="video-card">
          <div class="thumb">
            <img src={`https://img.youtube.com/vi/${v.data.youtubeId}/mqdefault.jpg`} alt={v.data.title} loading="lazy"/>
            <div class="play-overlay-sm">▶</div>
          </div>
          <div class="card-body">
            <div class="card-tag">{v.data.theme}</div>
            <div class="card-title">{v.data.title}</div>
            <div class="card-desc">{v.data.description}</div>
          </div>
        </a>
      ))}
    </div>
  </div>

  <!-- NYX NIGHTSHADE -->
  <div class="section">
    <div class="section-head">
      <div class="section-label nyx-label">◈ Nyx Nightshade</div>
      <span class="nyx-badge">Series</span>
    </div>
    <div class="section-desc">AI-generated transmissions. Surrealist dispatches from the edge.</div>
    <div class="nyx-grid">
      {shorts.map(v => (
        <a href={`https://youtube.com/shorts/${v.data.youtubeId}`} target="_blank" class="nyx-card">
          <div class="nyx-thumb">
            <img src={`https://img.youtube.com/vi/${v.data.youtubeId}/mqdefault.jpg`} alt={v.data.title} loading="lazy"/>
            <div class="play-overlay-sm">▶</div>
          </div>
          <div class="card-body">
            <div class="card-tag">{v.data.theme}</div>
            <div class="card-title">{v.data.title}</div>
          </div>
        </a>
      ))}
    </div>
  </div>

  <div class="channel-link">
    <span class="channel-text">76 videos and counting</span>
    <a href="https://youtube.com/channel/UClWbNxQMrx-XB3h8xXh_oxQ/" target="_blank" class="watch-btn">↗ Full channel on YouTube</a>
  </div>

  <Footer />

</Layout>

<style>
  :global(body) { overflow-x: hidden; }

  .page-header {
    padding: 64px 40px 48px;
    border-bottom: 1px solid rgba(139,92,246,0.08);
    max-width: 700px;
  }
  .eyebrow {
    font-size: 10px;
    letter-spacing: 0.5em;
    color: #4c3d6e;
    margin-bottom: 16px;
    font-family: 'Cinzel', serif;
    text-transform: uppercase;
  }
  h1 {
    font-family: 'Cinzel', serif;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 400;
    color: #f0ecff;
    margin-bottom: 16px;
    letter-spacing: 0.04em;
  }
  .intro {
    font-size: 16px;
    color: #5a4f7a;
    font-weight: 300;
    line-height: 1.8;
  }

  /* FEATURED */
  .featured-wrap {
    padding: 40px 40px 0;
    border-bottom: 1px solid rgba(139,92,246,0.08);
    padding-bottom: 48px;
  }
  .featured {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 1px;
    background: rgba(139,92,246,0.08);
    margin-top: 24px;
  }
  .featured-thumb {
    position: relative;
    display: block;
    overflow: hidden;
  }
  .featured-thumb img {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
    display: block;
    opacity: 0.8;
    transition: opacity 0.2s;
  }
  .featured-thumb:hover img { opacity: 1; }
  .play-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(9,9,15,0.4);
    transition: background 0.2s;
  }
  .featured-thumb:hover .play-overlay { background: rgba(9,9,15,0.2); }
  .play-btn {
    width: 56px; height: 56px;
    border-radius: 50%;
    border: 1px solid rgba(167,139,250,0.5);
    display: flex; align-items: center; justify-content: center;
    font-size: 18px; color: #c4b5fd;
    background: rgba(109,40,217,0.2);
  }
  .featured-info {
    background: #09090f;
    padding: 36px 32px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .featured-badge {
    font-size: 10px;
    letter-spacing: 0.3em;
    color: #4c3d6e;
    font-family: 'Cinzel', serif;
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .featured-badge::before {
    content: '';
    width: 5px; height: 5px;
    border-radius: 50%;
    background: #a78bfa;
    display: inline-block;
  }
  .featured-info h2 {
    font-family: 'Cinzel', serif;
    font-size: 17px;
    font-weight: 400;
    color: #e2d9f3;
    line-height: 1.5;
    margin-bottom: 12px;
    letter-spacing: 0.02em;
  }
  .featured-info p {
    font-size: 14px;
    color: #5a4f7a;
    line-height: 1.7;
    font-weight: 300;
    margin-bottom: 24px;
  }
  .watch-btn {
    font-family: 'Cinzel', serif;
    font-size: 11px;
    letter-spacing: 0.2em;
    color: #c4b5fd;
    border: 1px solid rgba(167,139,250,0.3);
    padding: 10px 20px;
    background: rgba(109,40,217,0.1);
    text-decoration: none;
    transition: background 0.2s;
    width: fit-content;
  }
  .watch-btn:hover { background: rgba(109,40,217,0.25); }

  /* SECTIONS */
  .section {
    padding: 48px 40px;
    border-bottom: 1px solid rgba(139,92,246,0.06);
  }
  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 8px;
  }
  .section-label {
    font-size: 10px;
    letter-spacing: 0.4em;
    color: #4c3d6e;
    font-family: 'Cinzel', serif;
    text-transform: uppercase;
  }
  .nyx-label { color: #9d4d6e; }
  .nyx-badge {
    font-size: 9px;
    letter-spacing: 0.2em;
    color: #9d4d6e;
    border: 1px solid rgba(157,77,110,0.25);
    padding: 3px 8px;
    font-family: 'Cinzel', serif;
  }
  .section-more {
    font-size: 11px;
    letter-spacing: 0.15em;
    color: #3d2f5c;
    font-family: 'Cinzel', serif;
    text-decoration: none;
    transition: color 0.15s;
  }
  .section-more:hover { color: #6d5a8a; }
  .section-desc {
    font-size: 13px;
    color: #3d2f5c;
    font-weight: 300;
    margin-bottom: 28px;
    letter-spacing: 0.02em;
  }

  /* VIDEO GRID */
  .video-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1px;
    background: rgba(139,92,246,0.06);
  }
  .video-card {
    background: #09090f;
    text-decoration: none;
    color: inherit;
    transition: background 0.15s;
    display: block;
  }
  .video-card:hover { background: rgba(109,40,217,0.05); }
  .thumb {
    position: relative;
    overflow: hidden;
  }
  .thumb img {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
    display: block;
    opacity: 0.75;
    transition: opacity 0.2s;
  }
  .video-card:hover .thumb img { opacity: 1; }
  .play-overlay-sm {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    color: rgba(167,139,250,0.6);
    opacity: 0;
    transition: opacity 0.2s;
  }
  .video-card:hover .play-overlay-sm { opacity: 1; }
  .card-body { padding: 16px; }
  .card-tag {
    font-size: 9px;
    letter-spacing: 0.25em;
    color: #3d2f5c;
    font-family: 'Cinzel', serif;
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .card-title {
    font-size: 13px;
    color: #8a7aaa;
    line-height: 1.5;
    font-weight: 300;
    margin-bottom: 6px;
    transition: color 0.15s;
  }
  .video-card:hover .card-title { color: #c4b5fd; }
  .card-desc {
    font-size: 12px;
    color: #3d2f5c;
    line-height: 1.5;
    font-weight: 300;
  }

  /* NYX GRID */
  .nyx-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1px;
    background: rgba(157,77,110,0.06);
  }
  .nyx-card {
    background: #09090f;
    text-decoration: none;
    color: inherit;
    transition: background 0.15s;
    display: block;
  }
  .nyx-card:hover { background: rgba(157,77,110,0.04); }
  .nyx-thumb {
    position: relative;
    overflow: hidden;
  }
  .nyx-thumb img {
    width: 100%;
    aspect-ratio: 9/16;
    object-fit: cover;
    display: block;
    opacity: 0.75;
    transition: opacity 0.2s;
  }
  .nyx-card:hover .nyx-thumb img { opacity: 1; }
  .nyx-card:hover .play-overlay-sm { opacity: 1; }

  /* CHANNEL LINK */
  .channel-link {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 24px;
    padding: 32px 40px;
    border-bottom: 1px solid rgba(139,92,246,0.06);
  }
  .channel-text {
    font-family: 'Cinzel', serif;
    font-size: 11px;
    letter-spacing: 0.25em;
    color: #3d2f5c;
  }

  @media (max-width: 800px) {
    .page-header { padding: 40px 24px 32px; }
    .featured { grid-template-columns: 1fr; }
    .featured-wrap { padding: 32px 24px; }
    .section { padding: 36px 24px; }
    .channel-link { flex-direction: column; gap: 16px; padding: 28px 24px; }
  }
</style>