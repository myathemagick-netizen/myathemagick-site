---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-left">
      <div class="eyebrow">Myathe Magick System</div>
      <h1>Thirty years at the<br><em>edge of the map</em></h1>
      <p class="tagline">A living system at the intersection of sacred geometry, chaos magick, torsion field physics, and the structure of time itself.</p>
      <div class="cta-row">
        <a href="/system" class="btn-primary">Enter the System</a>
        <a href="/tools" class="btn-ghost">Explore the tools</a>
      </div>
    </div>
    <div class="hero-right">
      <div class="globe-wrap">
        <svg viewBox="0 0 280 280" width="280" height="280">
          <defs>
            <linearGradient id="gg" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#c084fc" stop-opacity="0.6"/>
              <stop offset="100%" stop-color="#6d28d9" stop-opacity="0.2"/>
            </linearGradient>
          </defs>
          <circle cx="140" cy="140" r="130" fill="none" stroke="rgba(139,92,246,0.1)" stroke-width="1"/>
          <circle cx="140" cy="140" r="100" fill="none" stroke="rgba(139,92,246,0.07)" stroke-width="1"/>
          <g stroke="rgba(139,92,246,0.3)" stroke-width="0.8" fill="none">
            <line x1="140" y1="10" x2="220" y2="70"/>
            <line x1="220" y1="70" x2="260" y2="160"/>
            <line x1="260" y1="160" x2="220" y2="240"/>
            <line x1="220" y1="240" x2="140" y2="270"/>
            <line x1="140" y1="270" x2="60" y2="240"/>
            <line x1="60" y1="240" x2="20" y2="160"/>
            <line x1="20" y1="160" x2="60" y2="70"/>
            <line x1="60" y1="70" x2="140" y2="10"/>
            <line x1="140" y1="10" x2="140" y2="140"/>
            <line x1="220" y1="70" x2="140" y2="140"/>
            <line x1="260" y1="160" x2="140" y2="140"/>
            <line x1="220" y1="240" x2="140" y2="140"/>
            <line x1="140" y1="270" x2="140" y2="140"/>
            <line x1="60" y1="240" x2="140" y2="140"/>
            <line x1="20" y1="160" x2="140" y2="140"/>
            <line x1="60" y1="70" x2="140" y2="140"/>
          </g>
          <g fill="rgba(167,139,250,0.6)">
            <circle cx="140" cy="10" r="3"/>
            <circle cx="220" cy="70" r="3"/>
            <circle cx="260" cy="160" r="3"/>
            <circle cx="220" cy="240" r="3"/>
            <circle cx="140" cy="270" r="3"/>
            <circle cx="60" cy="240" r="3"/>
            <circle cx="20" cy="160" r="3"/>
            <circle cx="60" cy="70" r="3"/>
          </g>
          <circle cx="140" cy="140" r="5" fill="#a78bfa"/>
        </svg>
        <div class="live-label">
          <span class="live-dot"></span>
          Live Earth Sync
        </div>
      </div>
    </div>
  </section>

  <!-- EARTH BAR -->
  <div class="earth-bar">
    <div class="earth-item">
      <span class="earth-val">7.83 Hz</span>
      <span class="earth-key">Schumann SR1</span>
    </div>
    <div class="earth-sep"></div>
    <div class="earth-item">
      <span class="earth-val">Kp 2</span>
      <span class="earth-key">Geomagnetic</span>
    </div>
    <div class="earth-sep"></div>
    <div class="earth-item">
      <span class="earth-val">412 km/s</span>
      <span class="earth-key">Solar wind</span>
    </div>
    <div class="earth-sep"></div>
    <div class="earth-item">
      <span class="earth-val">4 Ajaw</span>
      <span class="earth-key">Tzolkin</span>
    </div>
    <div class="earth-sep"></div>
    <a href="/tools#audio-shear-zone" class="earth-cta">↗ Audio Shear Zone — attune now</a>
  </div>

  <!-- STATS -->
  <div class="stats-bar">
    <div class="stat"><div class="stat-num">7</div><div class="stat-label">Crystal Path elements</div></div>
    <div class="stat"><div class="stat-num">20</div><div class="stat-label">Icosahedral riftlines</div></div>
    <div class="stat"><div class="stat-num">30</div><div class="stat-label">Years of system-building</div></div>
    <div class="stat"><div class="stat-num">∞</div><div class="stat-label">Dragons at the edge</div></div>
  </div>

  <!-- CRYSTAL PATH -->
  <section class="cp-section">
    <div class="section-label">The Crystal Path</div>
    <div class="cp-stack">
      <a href="/system#chaos" class="cp-node">
        <div class="cp-left"><span class="cp-icon">∞</span><div><div class="cp-name">Chaos / Spirit</div><div class="cp-sub">Crown · dissolution · the field beyond form</div></div></div>
        <span class="cp-num">VII</span>
      </a>
      <a href="/system#cosmos" class="cp-node">
        <div class="cp-left"><span class="cp-icon">✦</span><div><div class="cp-name">Cosmos / Light</div><div class="cp-sub">Third Eye · chronon flow · riftline perception</div></div></div>
        <span class="cp-num">VI</span>
      </a>
      <a href="/system#ethos" class="cp-node">
        <div class="cp-left"><span class="cp-icon">⟡</span><div><div class="cp-name">Ethos / Will</div><div class="cp-sub">Throat · directed intent · sigilization</div></div></div>
        <span class="cp-num">V</span>
      </a>
      <a href="/system#noos" class="cp-node">
        <div class="cp-left"><span class="cp-icon">⬡</span><div><div class="cp-name">Noos / Mind</div><div class="cp-sub">Heart · resonance · sacred geometry</div></div></div>
        <span class="cp-num">IV</span>
      </a>
      <a href="/system#pathos" class="cp-node">
        <div class="cp-left"><span class="cp-icon">◈</span><div><div class="cp-name">Pathos / Heart</div><div class="cp-sub">Solar Plexus · Egoform dissolution · alchemical fire</div></div></div>
        <span class="cp-num">III</span>
      </a>
      <a href="/system#bios" class="cp-node">
        <div class="cp-left"><span class="cp-icon">◉</span><div><div class="cp-name">Bios / Body</div><div class="cp-sub">Sacral · torsion field grounding · earth current</div></div></div>
        <span class="cp-num">II</span>
      </a>
      <a href="/system#logos" class="cp-node">
        <div class="cp-left"><span class="cp-icon">▽</span><div><div class="cp-name">Logos / Shadow</div><div class="cp-sub">Root · the calcified mass · beginning of dissolution</div></div></div>
        <span class="cp-num">I</span>
      </a>
    </div>
  </section>

  <!-- TOOLS -->
  <section class="tools-section">
    <div class="section-label" style="padding: 40px 40px 0;">Tools</div>
    <div class="tools-grid">
      <a href="https://myathemagick-netizen.github.io/audio-shear-zone/" target="_blank" class="tool-card">
        <div class="tool-icon">◉</div>
        <div class="tool-name">Audio Shear Zone</div>
        <div class="tool-desc">Binaural attunement engine. 25 Crystal Path presets, Solfeggio carriers, environmental soundscapes, and Live Earth Sync via NOAA space weather data.</div>
        <div class="tool-link">↗ Open tool</div>
      </a>
      <a href="https://myathemagick-netizen.github.io/RiVViT/" target="_blank" class="tool-card">
        <div class="tool-icon">⬡</div>
        <div class="tool-name">RiVViT</div>
        <div class="tool-desc">An interactive VR globe mapping the icosahedral riftline network across the Earth's surface. Open in any browser or headset.</div>
        <div class="tool-link">↗ Open globe</div>
      </a>
    </div>
  </section>

<!-- FOOTER -->
  <footer>
    <div class="footer-logo">Myathe Magick System</div>
    <div class="footer-links">
      <a href="https://youtube.com/channel/UClWbNxQMrx-XB3h8xXh_oxQ/" target="_blank">YouTube</a>
      <a href="https://myathemagick.substack.com/" target="_blank">Substack</a>
      <a href="https://ko-fi.com/myathemagick" target="_blank">Ko-fi</a>
      <a href="https://www.facebook.com/profile.php?id=61563102456940" target="_blank">Facebook</a>
      <a href="https://x.com/MyatheMagick" target="_blank">X</a>
    </div>
  </footer>

</Layout>

<style>
  :global(body) { overflow-x: hidden; }

  /* HERO */
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 480px;
    width: 100%;
    border-bottom: 1px solid rgba(139,92,246,0.08);
  }
  .hero-left {
    padding: 64px 48px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    border-right: 1px solid rgba(139,92,246,0.08);
  }
  .eyebrow {
    font-size: 10px;
    letter-spacing: 0.5em;
    color: #4c3d6e;
    margin-bottom: 20px;
    font-family: 'Cinzel', serif;
    text-transform: uppercase;
  }
  h1 {
    font-family: 'Cinzel', serif;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 400;
    color: #f0ecff;
    line-height: 1.3;
    margin-bottom: 24px;
    letter-spacing: 0.04em;
  }
  h1 em {
    font-style: italic;
    font-family: 'Crimson Pro', serif;
    color: #a78bfa;
  }
  .tagline {
    font-size: 16px;
    color: #7c6a99;
    line-height: 1.8;
    margin-bottom: 36px;
    font-weight: 300;
    max-width: 360px;
  }
  .cta-row { display: flex; gap: 12px; align-items: center; }
  .btn-primary {
    font-family: 'Cinzel', serif;
    font-size: 11px;
    letter-spacing: 0.25em;
    color: #c4b5fd;
    border: 1px solid rgba(167,139,250,0.35);
    padding: 10px 24px;
    background: rgba(109,40,217,0.14);
    transition: background 0.2s;
    text-decoration: none;
  }
  .btn-primary:hover { background: rgba(109,40,217,0.28); }
  .btn-ghost {
    font-family: 'Cinzel', serif;
    font-size: 11px;
    letter-spacing: 0.25em;
    color: #4c3d6e;
    padding: 10px 0;
    transition: color 0.2s;
    text-decoration: none;
  }
  .btn-ghost:hover { color: #9d8cd4; }
  .hero-right {
    background: #07070d;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    min-height: 400px;
  }
  .globe-wrap { position: relative; }
  .live-label {
    position: absolute;
    bottom: -28px;
    right: 0;
    font-size: 10px;
    letter-spacing: 0.2em;
    color: #3d6648;
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: 'Cinzel', serif;
  }
  .live-dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: #4ade80;
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }

  /* EARTH BAR */
  .earth-bar {
    display: flex;
    align-items: center;
    gap: 32px;
    padding: 16px 40px;
    border-bottom: 1px solid rgba(139,92,246,0.06);
    background: rgba(7,7,13,0.8);
    flex-wrap: wrap;
    width: 100%;
  }
  .earth-item { display: flex; flex-direction: column; }
  .earth-val { font-family: 'Cinzel', serif; font-size: 14px; color: #9d8cd4; }
  .earth-key { font-size: 10px; letter-spacing: 0.2em; color: #3d2f5c; margin-top: 2px; }
  .earth-sep { width: 1px; height: 32px; background: rgba(139,92,246,0.1); }
  .earth-cta {
    font-family: 'Cinzel', serif;
    font-size: 11px;
    letter-spacing: 0.15em;
    color: #3d2f5c;
    margin-left: auto;
    transition: color 0.15s;
    text-decoration: none;
  }
  .earth-cta:hover { color: #9d8cd4; }

  /* STATS */
  .stats-bar {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-bottom: 1px solid rgba(139,92,246,0.08);
    width: 100%;
  }
  .stat {
    padding: 24px 32px;
    border-right: 1px solid rgba(139,92,246,0.08);
  }
  .stat:last-child { border-right: none; }
  .stat-num {
    font-family: 'Cinzel', serif;
    font-size: 22px;
    color: #9d8cd4;
    margin-bottom: 4px;
  }
  .stat-label { font-size: 11px; letter-spacing: 0.2em; color: #3d2f5c; }

  /* CRYSTAL PATH */
  .cp-section {
    padding: 56px 40px;
    border-bottom: 1px solid rgba(139,92,246,0.06);
  }
  .section-label {
    font-size: 10px;
    letter-spacing: 0.5em;
    color: #4c3d6e;
    margin-bottom: 32px;
    font-family: 'Cinzel', serif;
    text-transform: uppercase;
  }
  .cp-stack {
    display: flex;
    flex-direction: column;
    max-width: 560px;
    margin: 0 auto;
  }
  .cp-node {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 20px;
    border: 1px solid rgba(139,92,246,0.12);
    border-bottom: none;
    cursor: pointer;
    transition: background 0.15s;
    text-decoration: none;
    color: inherit;
  }
  .cp-node:last-child { border-bottom: 1px solid rgba(139,92,246,0.12); }
  .cp-node:hover { background: rgba(109,40,217,0.08); }
  .cp-left { display: flex; align-items: center; gap: 16px; }
  .cp-icon { font-size: 16px; color: #5a4880; width: 20px; text-align: center; }
  .cp-name { font-family: 'Cinzel', serif; font-size: 13px; color: #c4b5fd; letter-spacing: 0.05em; }
  .cp-sub { font-size: 12px; color: #4c3d6e; letter-spacing: 0.08em; margin-top: 2px; }
  .cp-num { font-size: 11px; color: #3d2f5c; letter-spacing: 0.1em; font-family: 'Cinzel', serif; }

  /* TOOLS */
  .tools-section {
    border-bottom: 1px solid rgba(139,92,246,0.06);
    padding-bottom: 0;
  }
  .tools-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: rgba(139,92,246,0.08);
    margin-top: 24px;
    width: 100%;
  }
  .tool-card {
    background: #09090f;
    padding: 36px 32px;
    transition: background 0.15s;
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .tool-card:hover { background: rgba(109,40,217,0.06); }
  .tool-icon { font-size: 22px; color: #4c3d6e; margin-bottom: 16px; }
  .tool-name {
    font-family: 'Cinzel', serif;
    font-size: 16px;
    color: #c4b5fd;
    margin-bottom: 8px;
    letter-spacing: 0.04em;
  }
  .tool-desc { font-size: 14px; color: #5a4f7a; line-height: 1.7; margin-bottom: 20px; font-weight: 300; }
  .tool-link { font-size: 11px; letter-spacing: 0.2em; color: #4c3d6e; font-family: 'Cinzel', serif; }
  .tool-card:hover .tool-link { color: #9d8cd4; }

  /* FOOTER */
  footer {
    padding: 32px 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid rgba(139,92,246,0.08);
  }
  .footer-logo {
    font-family: 'Cinzel', serif;
    font-size: 11px;
    letter-spacing: 0.3em;
    color: #3d2f5c;
  }
  .footer-links { display: flex; gap: 24px; }
  .footer-links a {
    font-size: 11px;
    letter-spacing: 0.15em;
    color: #3d2f5c;
    font-family: 'Cinzel', serif;
    transition: color 0.15s;
  }
  .footer-links a:hover { color: #6d5a8a; }
</style>