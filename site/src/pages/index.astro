---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
  <main>
    <h1>Myathe Magick</h1>
    <p>System initializing...</p>
  </main>
</Layout>

<style>
  main {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    font-family: 'Cinzel', serif;
    color: #9d8cd4;
    letter-spacing: 0.1em;
	background: #09090f;
  }
  h1 {
    font-size: 2rem;
    font-weight: 400;
    color: #f0ecff;
    margin-bottom: 1rem;
  }
  p {
    font-size: 0.8rem;
    letter-spacing: 0.3em;
    color: #3d2f5c;
  }
</style>